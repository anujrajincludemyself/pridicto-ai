# ========================================
# PRIDICTO - ENVIRONMENT VARIABLES GUIDE
# ========================================
# Copy this file to .env and fill in your values

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# SUPABASE (Free Database)
# Get from: https://supabase.com → Create Project → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# PostgreSQL connection (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:yourpassword@db.your-project-id.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# UPSTASH REDIS (Free Cache - 10k req/day)
# Get from: https://upstash.com → Create Database → REST API section
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────
# RAPIDAPI - Indian Railways Data
# Get from: https://rapidapi.com → Search "Indian Railways API"
# Recommended: "Indian Railways" by IRCTC API or "RailwayAPI"
# Subscribe to free plan → copy X-RapidAPI-Key from Code Snippets
# ─────────────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=indian-railway-irctc.p.rapidapi.com

# ─────────────────────────────────────────────
# INDIAN RAIL API (Seat Availability)
# Get from: https://indianrailapi.com
# ─────────────────────────────────────────────
INDIAN_RAIL_API_KEY=your-indianrailapi-key

# ─────────────────────────────────────────────
# ANTHROPIC CLAUDE API (AI Layer)
# BEST FREE MODEL: claude-3-haiku-20240307 (fastest, cheapest)
# Get from: https://console.anthropic.com → API Keys
# Free credits given on signup
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-haiku-20240307

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
